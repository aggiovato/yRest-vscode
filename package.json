{
  "name": "yrest",
  "displayName": "YRest Language Support",
  "description": "Syntax highlighting, diagnostics and autocompletion for YRest YAML files (db.yml).",
  "version": "0.1.0",
  "publisher": "aggiovato",
  "license": "MIT",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Programming Languages",
    "Linters"
  ],
  "keywords": [
    "yrest",
    "yaml",
    "mock",
    "rest",
    "api"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/aggiovato/yRest-vscode.git"
  },
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "yrest",
        "aliases": [
          "YRest",
          "yrest"
        ],
        "extensions": [
          ".yrest.yml",
          ".yrest.yaml"
        ],
        "filenames": [
          "db.yml",
          "db.yaml"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "yrest",
        "scopeName": "source.yrest",
        "path": "./syntaxes/yrest.tmLanguage.json"
      },
      {
        "scopeName": "yrest.injection",
        "path": "./syntaxes/yrest-injection.json",
        "injectTo": ["source.ts", "source.js", "source.tsx", "source.jsx"],
        "embeddedLanguages": {
          "meta.embedded.block.yrest": "yrest"
        }
      }
    ]
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package",
    "lint": "eslint src"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.90.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.0.0",
    "typescript": "^5.4.0",
    "@vscode/vsce": "^2.26.0"
  },
  "dependencies": {
    "yaml": "^2.4.0"
  }
}
